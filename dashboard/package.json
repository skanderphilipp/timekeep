{
  "name": "@skanderphilipp/timekeep-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "timekeep management dashboard — React SPA with SCSS Modules, base-ui, Lingui i18n",
  "license": "AGPL-3.0",
  "author": "Skander Ben Abdelmalak <skander@bentech.app>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:oxlint-rules && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm build:oxlint-rules && oxlint",
    "depcruise": "depcruise src --config .dependency-cruiser.mjs",
    "depcruise:graph": "depcruise src --config .dependency-cruiser.mjs --output-type dot | dot -T svg > docs/dependency-graph.svg",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate-tokens": "tsx -e \"import { generateThemeCSS } from './src/styles/tokens/build.ts'; process.stdout.write(generateThemeCSS());\" > src/styles/generated-tokens.css",
    "generate-api-types": "openapi-typescript http://localhost:3000/api/docs/openapi.json -o generated/api-types.ts",
    "check-api-types": "pnpm generate-api-types && git diff --exit-code generated/api-types.ts",
    "generate-shared": "tsx ../scripts/generate-shared.ts",
    "generate-ui-barrel": "tsx ../scripts/generate-ui-barrel.ts",
    "check-ui-barrel": "tsx ../scripts/generate-ui-barrel.ts --check",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:storybook": "vitest run --project storybook",
    "build:oxlint-rules": "cd packages/oxlint-rules && node build.mjs",
    "lint:fix": "pnpm build:oxlint-rules && oxlint --fix",
    "check-size": "bash scripts/check-file-size.sh src",
    "lint:style": "stylelint \"src/**/*.scss\"",
    "lint:style:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:tokens": "tsx scripts/check-tokens.ts",
    "check:dupes": "jscpd src --config .jscpd.json",
    "check:unused": "knip --include files,exports",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm depcruise && pnpm check-size && pnpm lint:style && pnpm lint:tokens && pnpm check:dupes",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepare": "husky && npx msw init public/ --save"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@floating-ui/react": "^0.26.28",
    "@fontsource/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@lingui/core": "^5.9.5",
    "@lingui/detect-locale": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@monaco-editor/react": "^4.7.0",
    "@nivo/bar": "^0.99.0",
    "@nivo/bump": "^0.99.0",
    "@nivo/calendar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@nivo/radar": "^0.99.0",
    "@nivo/scatterplot": "^0.99.0",
    "@nivo/stream": "^0.99.0",
    "@radix-ui/colors": "^3.0.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "es-toolkit": "^1.49.0",
    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "jotai": "^2.20.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "ky": "^2.0.2",
    "monaco-editor": "^0.55.1",
    "postcss-rtlcss": "^6.0.0",
    "react": "^19.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.81.0",
    "react-hotkeys-hook": "^5.3.3",
    "react-imask": "^7.6.1",
    "react-intersection-observer": "^10.1.0",
    "react-loading-skeleton": "^3.5.0",
    "react-responsive": "^9.0.2",
    "react-router-dom": "^7.18.1",
    "react-textarea-autosize": "^8.5.9",
    "rtl-detect": "^1.1.2",
    "temporal-polyfill": "^0.3.2",
    "type-fest": "^4.10.1",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bentech/oxlint-rules": "workspace:*",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@lingui/cli": "^5.9.5",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.5",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/addon-links": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@storybook/test": "^8.6.15",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jspdf": "^2.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "code-inspector-plugin": "^1.6.6",
    "dependency-cruiser": "^18.0.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.12",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "playwright": "^1.61.1",
    "react-scan": "^0.5.7",
    "sass": "^1.101.0",
    "storybook": "^10.5.0",
    "storybook-addon-pseudo-states": "^4.0.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-sass-dts": "^1.3.31",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.10.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
