# ─── timekeep ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# ───────────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 48
TIMEKEEP_JWT_SECRET=change-me-to-a-random-64-char-string

# Initial admin credentials (only used on first run)
TIMEKEEP_ADMIN_USER=admin
TIMEKEEP_ADMIN_PASSWORD=change-me

# ── Database ───────────────────────────────────────────────────────
# Default: SQLite at ./timekeep.db
# TIMEKEEP_DB_PATH=/var/lib/timekeep/timekeep.db

# Switch to PostgreSQL:
# TIMEKEEP_DB_BACKEND=postgres
# DATABASE_URL=postgres://timekeep:password@localhost:5432/timekeep

# ── Network ────────────────────────────────────────────────────────
# TIMEKEEP_API_PORT=3000
# TIMEKEEP_INTEGRATION_PORT=3001

# ── ZKTeco SDK ─────────────────────────────────────────────────────
# TIMEKEEP_POLL_INTERVAL_SECS=60
# TIMEKEEP_AUTO_DISCOVER=false

# ── Webhook Distribution (optional) ────────────────────────────────
# TIMEKEEP_WEBHOOK_URL=http://localhost:9999/webhook
# TIMEKEEP_WEBHOOK_SECRET=your-webhook-hmac-secret

# ── Odoo Distribution (optional) ───────────────────────────────────
# ODOO_URL=https://odoo.example.local/json/2
# ODOO_API_KEY=your-odoo-api-key
# ODOO_DATABASE=example

# ── Observability (optional) ───────────────────────────────────────
# RUST_LOG=timekeep=debug
# TIMEKEEP_OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=timekeep
